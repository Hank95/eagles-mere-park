# Copy to .env.local and fill in real values.
# .env.local is gitignored.

# Supabase — get from your project's API settings.
# Note: Supabase recently renamed `anon` key to `publishable` key. Both work; we use the new name.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never expose to the client. Used for admin operations (invite-user, role assignment).
SUPABASE_SERVICE_ROLE_KEY=

# App origin for outbound links (invite emails, etc). In dev defaults to http://localhost:3000.
# Set this in prod to the public URL of the site (e.g., https://eaglesmerepark.com).
NEXT_PUBLIC_APP_URL=

# Resend — for transactional email and the weekly digest.
RESEND_API_KEY=
